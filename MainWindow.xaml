<Window x:Class="Pawdopt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pawdopt"
        Height="950"
        Width="1200"
        Background="#F5F7F9">

    <Grid>

        <!-- PAGE STRUCTURE -->
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Grid Background="#EAF2F6" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="Images/logo.png"
                   Height="45"
                   Margin="20,10"
                   VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="Adopt" Margin="25,0" FontSize="16" Foreground="#2B6C8A"/>
                <TextBlock Text="Rehome" Margin="25,0" FontSize="16" Foreground="#2B6C8A"/>
                <TextBlock Text="Care Guide" Margin="25,0" FontSize="16" Foreground="#2B6C8A"/>
                <TextBlock Text="About Us" Margin="25,0" FontSize="16" Foreground="#2B6C8A"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <Button Content="Login"
                        Width="90"
                        Height="35"
                        Background="#0F3E53"
                        Foreground="White"
                        Margin="0,0,10,0"/>
                <Button Content="Register"
                        Width="90"
                        Height="35"
                        BorderBrush="#0F3E53"
                        BorderThickness="2"
                        Background="White"
                        Foreground="#0F3E53"/>
            </StackPanel>
        </Grid>

        <!-- BLUE STRIP -->
        <Grid Grid.Row="1" Background="#6FA9C3"/>

        <!-- ================= MAIN CONTENT ================= -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- HERO -->
                <Grid Margin="50">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="40">
                        <TextBlock Text="Give a New Life to"
                                   FontSize="40"
                                   Foreground="#5A2A2A"/>
                        <TextBlock Text="Pawdopt"
                                   FontSize="52"
                                   FontWeight="Bold"
                                   Foreground="#0F3E53"
                                   Margin="0,10,0,20"/>
                        <TextBlock Width="450"
                                   TextWrapping="Wrap"
                                   FontSize="16"
                                   Text="Pet adoption and rehoming are both vital aspects of animal welfare, offering hope and a fresh start to pets in need. Open your heart and your home to a shelter pet."/>

                        <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                            <Button Content="Adopt Now"
                                    Width="150"
                                    Height="45"
                                    Background="#0F3E53"
                                    Foreground="White"
                                    Margin="0,0,20,0"/>
                            <Button Content="Rehome Now"
                                    Width="150"
                                    Height="45"
                                    BorderBrush="#0F3E53"
                                    BorderThickness="2"
                                    Background="White"
                                    Foreground="#0F3E53"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">

                        <Ellipse Width="450"
                                 Height="450"
                                 Fill="#CFE5ED"/>

                        <Image Source="Images/pets.png"
                               Width="500"
                               Margin="0,60,-20,0"/>

                        <Ellipse Width="35"
                                 Height="35"
                                 Fill="#7EB7CE"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,80,40,0"/>

                        <Ellipse Width="20"
                                 Height="20"
                                 Fill="#7EB7CE"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Margin="40,0,0,100"/>
                    </Grid>
                </Grid>

                <!-- PET TITLE -->
                <TextBlock Text="Take a Look at Some of Our Pets"
                           FontSize="30"
                           HorizontalAlignment="Center"
                           Margin="0,40,0,30"
                           FontWeight="SemiBold"/>

                <!-- PET CARDS -->
                <StackPanel HorizontalAlignment="Center">

                    <WrapPanel HorizontalAlignment="Center">

                        <!-- CARD 1 -->
                        <Border Width="260" Height="370"
                                Background="White"
                                CornerRadius="12"
                                Margin="15"
                                Padding="15"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <StackPanel>
                                <Image Source="Images/dog1.jpg" Height="150"/>
                                <TextBlock Text="Pitter" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock Text="Quebec, Canada" Foreground="Gray"/>
                                <TextBlock Text="Male • 5 Years • Large" Margin="0,10,0,0"/>
                                <Button Content="More Info"
                                        Margin="0,20,0,0"
                                        Background="#0F3E53"
                                        Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 2 -->
                        <Border Width="260" Height="370"
                                Background="White"
                                CornerRadius="12"
                                Margin="15"
                                Padding="15"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <StackPanel>
                                <Image Source="Images/cat1.jpg" Height="150"/>
                                <TextBlock Text="Hero" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock Text="Alberta, Canada" Foreground="Gray"/>
                                <TextBlock Text="Male • 2 Years • Small" Margin="0,10,0,0"/>
                                <Button Content="More Info"
                                        Margin="0,20,0,0"
                                        Background="#0F3E53"
                                        Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- CARD 3 -->
                        <Border Width="260" Height="370"
                                Background="White"
                                CornerRadius="12"
                                Margin="15"
                                Padding="15"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <StackPanel>
                                <Image Source="Images/dog2.jpg" Height="150"/>
                                <TextBlock Text="Magie" FontWeight="Bold" Margin="0,10,0,5"/>
                                <TextBlock Text="Ontario, Canada" Foreground="Gray"/>
                                <TextBlock Text="Female • 3 Years • Medium" Margin="0,10,0,0"/>
                                <Button Content="More Info"
                                        Margin="0,20,0,0"
                                        Background="#0F3E53"
                                        Foreground="White"/>
                            </StackPanel>
                        </Border>

                    </WrapPanel>

                    <Button Content="See More"
                            Width="140"
                            Height="40"
                            Margin="0,25,0,50"
                            Background="White"
                            BorderBrush="#0F3E53"
                            BorderThickness="2"
                            Foreground="#0F3E53"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ================= FOOTER ================= -->
        <Grid Grid.Row="3" Background="#E9EFF2">
            <Grid Margin="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="How Can We Help?" FontWeight="Bold"/>
                    <TextBlock Text="Adopt a pet" Margin="0,10,0,0"/>
                    <TextBlock Text="Rehome a pet"/>
                    <TextBlock Text="Adopt FAQ's"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Contact Us" FontWeight="Bold"/>
                    <TextBlock Text="123 Main Street"/>
                    <TextBlock Text="+1 (514) 123-4567"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Keep In Touch With Us" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBox Width="180"/>
                        <Button Content="Subscribe"
                                Background="#0F3E53"
                                Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ================= FOOTER BOTTOM ================= -->
        <Grid Grid.Row="4" Background="#0F3E53">
            <Grid Margin="40,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="©2026 Pawdopt.com"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Image Source="Images/facebook.png"
                           Width="22"
                           Margin="10,0"/>
                    <Image Source="Images/instagram.png"
                           Width="22"
                           Margin="10,0"/>
                </StackPanel>
            </Grid>
        </Grid>

    </Grid>
</Window>