<Window x:Class="Pawdopt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pawdopt"
        Height="800" Width="1200"
        Background="#F5F7F9">

    <Grid>

        <!-- Navigation Bar -->
        <DockPanel Height="70" Background="#DDEEF5" VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Adopt" Margin="20" FontSize="16"/>
                <TextBlock Text="Rehome" Margin="20" FontSize="16"/>
                <TextBlock Text="Care Guide" Margin="20" FontSize="16"/>
                <TextBlock Text="About Us" Margin="20" FontSize="16"/>
            </StackPanel>

            <Button Content="Login / Register"
                    Width="140"
                    Height="35"
                    HorizontalAlignment="Right"
                    Margin="20"
                    Background="#0F3E53"
                    Foreground="White"
                    DockPanel.Dock="Right"/>
        </DockPanel>

        <!-- Hero Section -->
        <Grid Margin="0,100,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Text -->
            <StackPanel Margin="60">
                <TextBlock Text="Give a New Life to"
                           FontSize="36"
                           FontWeight="SemiBold"
                           Foreground="#5A2A2A"/>

                <TextBlock Text="Powdopt"
                           FontSize="48"
                           FontWeight="Bold"
                           Foreground="#0F3E53"
                           Margin="0,10,0,20"/>

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Width="400"
                           Text="Pet adoption and rehoming are both vital aspects of animal welfare, offering hope and a fresh start to pets in need."/>

                <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                    <Button Content="Adopt Now"
                            Width="140"
                            Height="45"
                            Background="#0F3E53"
                            Foreground="White"
                            Margin="0,0,20,0"/>

                    <Button Content="Rehome Now"
                            Width="140"
                            Height="45"
                            BorderBrush="#0F3E53"
                            BorderThickness="2"
                            Background="White"
                            Foreground="#0F3E53"/>
                </StackPanel>
            </StackPanel>

            <!-- Right Image -->
            <Image Grid.Column="1"
                   Source="Images/pets.png"
                   Stretch="Uniform"
                   Margin="20"/>
        </Grid>

        <!-- Pet Cards Section -->
        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,50">
            <TextBlock Text="Take a Look at Some of Our Pets"
                       FontSize="28"
                       HorizontalAlignment="Center"
                       Margin="0,40"/>

            <WrapPanel HorizontalAlignment="Center" Margin="20">

                <!-- Example Pet Card -->
                <Border Width="250"
                        Height="350"
                        Background="White"
                        CornerRadius="10"
                        Margin="15"
                        Padding="15"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1">

                    <StackPanel>
                        <Image Source="Images/dog1.jpg"
                               Height="150"
                               Stretch="Fill"/>

                        <TextBlock Text="Pitter"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,10,0,5"/>

                        <TextBlock Text="Quebec, Canada"
                                   FontSize="14"
                                   Foreground="Gray"/>

                        <TextBlock Text="Male • 5 Years • Large"
                                   Margin="0,10,0,0"/>

                        <Button Content="More Info"
                                Margin="0,20,0,0"
                                Background="#0F3E53"
                                Foreground="White"/>
                    </StackPanel>
                </Border>

            </WrapPanel>
        </StackPanel>

    </Grid>
</Window>
